{% extends "description.j2" %}
{% block content %}
{{ block_type }} {{ name }} {
  {% for opt in options %}
  option {{ opt }};
  {% endfor %}

  {% if reserveds[0] %}
  reserved {{ reserveds[0] }};
  {% endif %}

  {% if reserveds[1] %}
  reserved {{ reserveds[1] }};
  {% endif %}

{% block fields %}
{% for field in fields %}
  {{ field }}
{% endfor %}
{% endblock %}
}
{% endblock %}
